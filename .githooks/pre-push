#!/bin/bash
#
# Pre-push hook: secret scan (gitleaks) + all checks (build, lint, vulncheck,
# test) before pushing.
# Install with: task hooks:install
#
# Pushes that only delete remote branches carry no new code, so the checks
# are skipped for them. Git reports a deletion as an all-zeros local sha on
# stdin: "<local ref> <local sha> <remote ref> <remote sha>".

set -e

zero=$(printf '0%.0s' {1..40})
has_update=false
while read -r _local_ref local_sha _remote_ref _remote_sha; do
    if [ "$local_sha" != "$zero" ]; then
        has_update=true
    fi
done

if [ "$has_update" = false ]; then
    echo "Push contains only deletions; skipping pre-push checks."
    exit 0
fi

echo "Running pre-push checks..."

if ! command -v task &> /dev/null; then
    echo "Error: 'task' is not installed."
    echo "Please install Task from https://taskfile.dev/installation/"
    exit 1
fi

# Secret scan first -- it is cheap (~300ms over full history) and a leak should
# fail fast, before the slow build/lint/test pass. Warn-and-skip if gitleaks is
# absent (not a Go-toolchain default); install it with: task install:deps
if command -v gitleaks &> /dev/null; then
    echo "Scanning history for secrets (gitleaks)..."
    task secrets
else
    echo "WARNING: gitleaks not found; skipping the history secret scan."
    echo "  Install it with: task install:deps"
fi

task all

echo "All pre-push checks passed!"
