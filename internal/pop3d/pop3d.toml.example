# Mail Server Configuration
# Shared by smtpd, pop3d, msgstore

# Shared configuration used by all mail services
[server]
hostname = "mail.example.com"
maildir = "/var/mail"

[server.tls]
cert_file = "/etc/ssl/certs/mail.pem"
key_file = "/etc/ssl/private/mail.key"
min_version = "1.2"

# POP3 Server Configuration
[pop3d]
log_level = "info"

# Credentials each protocol-handler subprocess is dropped to. Leave unset
# (0) to run handlers under the dispatcher's own credentials (dev and
# rootless setups). Mirrors smtpd's handler credential model.
# handler_uid = 902
# handler_gid = 903
# handler_groups = [903]

[pop3d.timeouts]
connection = "10m"      # POP3 sessions tend to be longer than SMTP
command = "1m"
idle = "30m"            # Auto-logout after inactivity (RFC 1939 recommends 10min minimum)

[pop3d.limits]
max_connections = 100   # Concurrent connections limit

[pop3d.metrics]
enabled = false
address = ":9101"
path = "/metrics"
# Health endpoints available at /health and /healthz

[[pop3d.listeners]]
address = ":110"
mode = "pop3"           # Plain POP3 with optional STLS

[[pop3d.listeners]]
address = ":995"
mode = "pop3s"          # Implicit TLS (POP3S)

# Future sections:
# [smtpd]
# [msgstore]
# [imap]
