# Web Admin Configuration

[webadmin]
listen_address = "localhost:8080"
domains_path = "/etc/mail/domains"
log_level = "info"

[webadmin.auth]
passwd_file = "/etc/mail/admin-passwd"

# Optional: RBAC roles file. If omitted, all authenticated admins have super_admin access.
# roles_file = "/etc/mail/admin-roles.toml"

[webadmin.audit]
# Optional: write JSON audit log lines to this file. If omitted, audit events go to slog only.
# log_file = "/var/log/webadmin/audit.log"

[webadmin.session]
timeout_minutes = 30

# Optional TLS configuration
# [webadmin.tls]
# cert_file = "/etc/ssl/certs/mail.pem"
# key_file = "/etc/ssl/private/mail.key"

# Optional: path to a shared rspamd settings file.
# webadmin reads and writes this file; smtpd reads it for rspamd connection settings.
# Both services must point to the same file.
# rspamd_file = "/etc/mail/rspamd.toml"
